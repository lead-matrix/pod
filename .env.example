# Environment Variables — POD Store

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (public key — safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# App URL
VITE_APP_URL=https://your-domain.vercel.app

# ─────────────────────────────────────────────────────────────
# The variables below are SERVER-SIDE ONLY (Supabase Edge Fns + Vercel)
# DO NOT prefix with VITE_ — they must never reach the browser
# ─────────────────────────────────────────────────────────────

# Supabase (service role — admin access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Printful
PRINTFUL_API_TOKEN=your-printful-api-token
PRINTFUL_STORE_ID=your-printful-store-id

# Stripe (secret key — server only)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=hello@yourdomain.com
